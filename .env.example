# Supabase — récupère ces valeurs dans Settings → API de ton projet.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role (secret, usage serveur uniquement).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Web Push (génère une paire avec `npx web-push generate-vapid-keys --json`).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:obemstudio@gmail.com

# Protège les endpoints cron Vercel.
CRON_SECRET=
